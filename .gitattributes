# Auto-detect text files and normalize them to LF in the repo
* text=auto

# Shell scripts and Docker files must stay LF (CRLF breaks them in containers)
*.sh text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Keep YAML/yml as LF (CI configs, Docker Compose)
*.yml text eol=lf
*.yaml text eol=lf

# Batch files — Windows-only, keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff2 binary
