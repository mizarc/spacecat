{
  "name": "astrokat",
  "version": "0.2.0-dev",
  "description": "A modular, multi-platform chatbot with useful features to enhance the chat experience.",
  "type": "module",
  "main": "dist/index.js",
  "repository": "github:mizarc/astrokat",
  "bugs": "https://github.com/mizarc/astrokat/issues",
  "homepage": "https://github.com/mizarc/astrokat#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "start": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "deploy": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs scripts/deploy-commands.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "build": "tsc"
  },
  "keywords": [
    "discord",
    "fluxer",
    "chatbot",
    "moderation",
    "typescript",
    "discord-js",
    "multi-platform"
  ],
  "author": "Mizarc <contact@mizarc.dev>",
  "license": "MIT",
  "dependencies": {
    "@fluxerjs/core": "^1.3.1",
    "better-sqlite3": "^12.10.0",
    "chrono-node": "^2.9.1",
    "discord.js": "^14.26.4",
    "gif-encoder": "^0.7.2",
    "mathjs": "^15.2.0",
    "node-emoji": "^2.2.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/gif-encoder": "^0.7.4",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.32.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
