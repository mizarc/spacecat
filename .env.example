# =============================================================================
# Astrokat — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.

# ── Chat Adapters ────────────────────────────────────────────────────────────
# Comma-separated list of platforms to connect to.
# Options: discord, fluxer  (or both: discord,fluxer)
ADAPTERS=discord,fluxer

# Discord Bot Token (required if ADAPTERS includes "discord")
# https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Fluxer Bot Token (required if ADAPTERS includes "fluxer")
FLUXER_TOKEN=your_fluxer_token_here

# Discord Application ID (only needed for deploying slash commands)
# Run: npm run deploy
DISCORD_ID=your_discord_application_id_here

# ── Reminder Storage ────────────────────────────────────────────────────────
# Leave DATABASE_URL unset/empty → uses SQLite (embedded, zero setup).
# Set DATABASE_URL → uses PostgreSQL (required for multi-instance deployments).
# DATABASE_URL=postgresql://user:password@host:5432/astrokat
